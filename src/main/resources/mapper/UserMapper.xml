<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hust.classroomreserve.mapper.UserMapper">
    <insert id="insertUser">
        INSERT INTO users (id, name, password) VALUES (#{id}, #{name}, #{password})
    </insert>
    <delete id="deleteUserById">
        DELETE FROM users WHERE id = #{id}
    </delete>
    <select id="getUserById" resultType="com.hust.classroomreserve.entity.Users">
        SELECT * FROM users WHERE id = #{id}
    </select>
    <update id="updateUser">
        UPDATE users SET name = #{name}, password = #{password} WHERE id = #{id}
    </update>
    <select id="getUsersByRole" resultType="com.hust.classroomreserve.entity.Users">
        SELECT * FROM users WHERE role = #{role}
    </select>
</mapper>
